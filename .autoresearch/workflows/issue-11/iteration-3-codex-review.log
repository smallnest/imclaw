    53	// LatencyTracker measures duration distributions for named operations.
    54	// It retains at most maxSamples recent observations in a ring buffer.
    55	type LatencyTracker struct {
    56		name    string
    57		mu      sync.Mutex
    58		samples [maxSamples]time.Duration
    59		head    int  // next write position
    60		count   int  // total observations written (capped at maxSamples)
    61	}
    62	
    63	// Observe records a duration and emits a structured log line.
    64	func (lt *LatencyTracker) Observe(d time.Duration) {
    65		lt.mu.Lock()
    66		lt.samples[lt.head] = d
    67		lt.head = (lt.head + 1) % maxSamples
    68		if lt.count < maxSamples {
    69			lt.count++
    70		}
    71		lt.mu.Unlock()
    72	
    73		log.Printf("[metrics] latency %s duration_ms=%.2f", lt.name, float64(d)/float64(time.Millisecond))
    74	}
    75	
    76	// Since returns a duration from the given start time. It is a convenience
    77	// wrapper intended for one-line usage: defer tracker.Since(time.Now())
    78	func (lt *LatencyTracker) Since(start time.Time) {
    79		lt.Observe(time.Since(start))
    80	}
    81	
    82	// Summary returns aggregate statistics (count, min, max, avg, p50, p95, p99).
    83	// Returns zero values if no samples have been recorded.
    84	func (lt *LatencyTracker) Summary() LatencySummary {
    85		lt.mu.Lock()
    86		n := lt.count
    87		samples := make([]time.Duration, n)
    88		// Ring buffer: if count < maxSamples, data is in samples[0:count].
    89		// Otherwise, head marks the oldest entry.
    90		if n < maxSamples {
    91			copy(samples, lt.samples[:n])
    92		} else {
    93			copy(samples, lt.samples[lt.head:])
    94			copy(samples[maxSamples-lt.head:], lt.samples[:lt.head])
    95		}
    96		lt.mu.Unlock()
    97	
    98		return computeSummary(lt.name, samples)
    99	}
   100	
   101	// LatencySummary holds aggregate latency statistics.
   102	type LatencySummary struct {
   103		Name  string
   104		Count int
   105		Min   time.Duration
   106		Max   time.Duration
   107		Avg   time.Duration
   108		P50   time.Duration
   109		P95   time.Duration
   110		P99   time.Duration
   111	}
   112	
   113	// ---- Gauge ----
   114	
   115	// Gauge tracks a point-in-time integer value.
   116	type Gauge struct {
   117		name  string
   118		value atomic.Int64
   119	}
   120	
   121	// Set updates the gauge value.
   122	func (g *Gauge) Set(v int64) {
   123		g.value.Store(v)
   124		log.Printf("[metrics] gauge %s=%d", g.name, v)
   125	}
   126	
   127	// Inc increments the gauge by 1.
   128	func (g *Gauge) Inc() int64 {
   129		v := g.value.Add(1)
   130		log.Printf("[metrics] gauge %s=%d", g.name, v)
   131		return v
   132	}
   133	
   134	// Dec decrements the gauge by 1.
   135	func (g *Gauge) Dec() int64 {
   136		v := g.value.Add(-1)
   137		log.Printf("[metrics] gauge %s=%d", g.name, v)
   138		return v
   139	}
   140	
   141	// Value returns the current gauge value.
   142	func (g *Gauge) Value() int64 {
   143		return g.value.Load()
   144	}
   145	
   146	// ---- Registry ----
   147	
   148	// Registry groups named metrics for a subsystem.
   149	type Registry struct {
   150		mu       sync.Mutex
   151		counters map[string]*Counter
   152		latency  map[string]*LatencyTracker
   153		gauges   map[string]*Gauge
   154	}
   155	
   156	// NewRegistry creates a new metrics registry.
   157	func NewRegistry() *Registry {
   158		return &Registry{
   159			counters: make(map[string]*Counter),
   160			latency:  make(map[string]*LatencyTracker),
   161			gauges:   make(map[string]*Gauge),
   162		}
   163	}
   164	
   165	// Counter returns (or creates) a counter by name.
   166	func (r *Registry) Counter(name string) *Counter {
   167		r.mu.Lock()
   168		defer r.mu.Unlock()
   169		if c, ok := r.counters[name]; ok {
   170			return c
   171		}
   172		c := &Counter{name: name}
   173		r.counters[name] = c
   174		return c
   175	}
   176	
   177	// Latency returns (or creates) a latency tracker by name.
   178	func (r *Registry) Latency(name string) *LatencyTracker {
   179		r.mu.Lock()
   180		defer r.mu.Unlock()
   181		if lt, ok := r.latency[name]; ok {
   182			return lt
   183		}
   184		lt := &LatencyTracker{name: name}
   185		r.latency[name] = lt
   186		return lt
   187	}
   188	
   189	// Gauge returns (or creates) a gauge by name.
   190	func (r *Registry) Gauge(name string) *Gauge {
   191		r.mu.Lock()
   192		defer r.mu.Unlock()
   193		if g, ok := r.gauges[name]; ok {
   194			return g
   195		}
   196		g := &Gauge{name: name}
   197		r.gauges[name] = g
   198		return g
   199	}
   200	
   201	// Snapshot returns a point-in-time snapshot of all metrics.
   202	func (r *Registry) Snapshot() Snapshot {
   203		r.mu.Lock()
   204		defer r.mu.Unlock()
   205	
   206		snap := Snapshot{
   207			Counters: make(map[string]int64, len(r.counters)),
   208			Gauges:   make(map[string]int64, len(r.gauges)),
   209			Latency:  make(map[string]LatencySummary, len(r.latency)),
   210		}
   211		for name, c := range r.counters {
   212			snap.Counters[name] = c.Value()
   213		}
   214		for name, g := range r.gauges {
   215			snap.Gauges[name] = g.Value()
   216		}
   217		for name, lt := range r.latency {
   218			snap.Latency[name] = lt.Summary()
   219		}
   220		return snap
   221	}
   222	
   223	// Snapshot is a point-in-time view of all registry metrics.
   224	type Snapshot struct {
   225		Counters map[string]int64
   226		Gauges   map[string]int64
   227		Latency  map[string]LatencySummary
   228	}
   229	
   230	// ---- Global default registry ----
   231	
   232	var defaultRegistry = NewRegistry()
   233	
   234	// Default returns the global default metrics registry.
   235	func Default() *Registry {
   236		return defaultRegistry
   237	}
   238	
   239	// Predefined metric names following dashboard-friendly conventions.
   240	// Naming: <subsystem>.<metric_name>
   241	const (
   242		// Session metrics
   243		SessionCreated       = "session.created"
   244		SessionDeleted       = "session.deleted"
   245		SessionActive        = "session.active_count"
   246		SessionPromptLatency = "session.prompt_latency"
   247	
   248		// Request metrics
   249		RequestTotal     = "request.total"
   250		RequestLatency   = "request.latency"
   251		RequestErrors    = "request.errors"
   252	
   253		// Tool metrics
   254		ToolCallCount    = "tool.call_count"
   255		ToolCallDuration = "tool.call_duration"
   256		ToolCallErrors   = "tool.call_errors"
   257	
   258		// Permission metrics
   259		PermissionDenials = "permission.denials"
   260	
   261		// Agent metrics
   262		AgentExecDuration = "agent.exec_duration"
   263		AgentExecFailures = "agent.exec_failures"
   264	
   265		// Output metrics
   266		OutputSize = "output.size_bytes"
   267	
   268		// Job metrics
   269		JobSubmitted  = "job.submitted"
   270		JobCompleted  = "job.completed"
   271		JobFailed     = "job.failed"
   272		JobDuration   = "job.duration"
   273	
   274		// Connection metrics
   275		WSConnections    = "ws.active_connections"
   276		WSSubscribers    = "ws.active_subscribers"
   277		WSDroppedSubs    = "ws.dropped_subscribers"
   278	)
   279	
   280	// ---- Event logging helpers ----
   281	
   282	// LogEvent emits a structured event log line for key operational events.
   283	func LogEvent(event, sessionID, requestID string, extra map[string]interface{}) {
   284		pairs := make([]interface{}, 0, 2+len(extra)*2)
   285		pairs = append(pairs, "event", event)
   286		if sessionID != "" {
   287			pairs = append(pairs, "session_id", sessionID)
   288		}
   289		if requestID != "" {
   290			pairs = append(pairs, "request_id", requestID)
   291		}
   292		for k, v := range extra {
   293			pairs = append(pairs, k, v)
   294		}
   295		log.Printf("[metrics] event "+repeatFormat(len(pairs)/2), pairs...)
   296	}
   297	
   298	func repeatFormat(n int) string {
   299		const pair = " %s=%v"
   300		result := ""
   301		for i := 0; i < n; i++ {
   302			result += pair
   303		}
   304		return result
   305	}
   306	
   307	// ---- Internal helpers ----
   308	
   309	func computeSummary(name string, samples []time.Duration) LatencySummary {
   310		s := LatencySummary{
   311			Name:  name,
   312			Count: len(samples),
   313		}
   314		if len(samples) == 0 {
   315			return s
   316		}
   317	
   318		// Sort a copy to compute percentiles
   319		sorted := make([]time.Duration, len(samples))
   320		copy(sorted, samples)
   321		sort.Sort(sortableDurations(sorted))
   322	
   323		n := len(sorted)
   324		s.Min = sorted[0]
   325		s.Max = sorted[n-1]
   326	
   327		var total time.Duration
   328		for _, d := range sorted {
   329			total += d
   330		}
   331		s.Avg = total / time.Duration(n)
   332		s.P50 = sorted[n*50/100]
   333		s.P95 = sorted[n*95/100]
   334		s.P99 = sorted[n*99/100]
   335	
   336		return s
   337	}
   338	
   339	type sortableDurations []time.Duration
   340	
   341	func (d sortableDurations) Len() int           { return len(d) }
   342	func (d sortableDurations) Less(i, j int) bool { return d[i] < d[j] }
   343	func (d sortableDurations) Swap(i, j int)      { d[i], d[j] = d[j], d[i] }
   344	
   345	// Truncate shortens s to at most maxLen bytes, appending "..." if truncated.
   346	func Truncate(s string, maxLen int) string {
   347		if len(s) <= maxLen {
   348			return s
   349		}
   350		return s[:maxLen] + "..."
   351	}

