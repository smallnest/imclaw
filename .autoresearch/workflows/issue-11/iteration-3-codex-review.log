   658	func (s *Server) authenticateHTTP(r *http.Request) bool {
   659		auth := r.Header.Get("Authorization")
   660		if len(auth) > 7 && auth[:7] == "Bearer " {
   661			return subtle.ConstantTimeCompare([]byte(auth[7:]), []byte(s.config.AuthToken)) == 1
   662		}
   663		return false
   664	}
   665	
   666	func (s *Server) authenticateWS(r *http.Request) bool {
   667		token := r.URL.Query().Get("token")
   668		if token == "" {
   669			auth := r.Header.Get("Authorization")
   670			if len(auth) > 7 && auth[:7] == "Bearer " {
   671				token = auth[7:]
   672			}
   673		}
   674		if token == "" {
   675			return false
   676		}
   677		return subtle.ConstantTimeCompare([]byte(token), []byte(s.config.AuthToken)) == 1
   678	}
