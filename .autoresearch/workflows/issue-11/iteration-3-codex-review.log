  1211	func buildStructuredEvents(parser *event.Parser, chunk agent.StreamChunk) []agent.Event {
  1212		if len(chunk.Events) > 0 {
  1213			return append([]agent.Event(nil), chunk.Events...)
  1214		}
  1215	
  1216		var events []agent.Event
  1217		if chunk.Type == "content" {
  1218			events = append(events, convertLegacyEvents(parser.Feed(chunk.Content))...)
  1219		}
  1220		if chunk.Type == "error" {
  1221			events = append(events, agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeError, Content: chunk.Content})
  1222		}
  1223		return events
  1224	}
  1225	
  1226	func flushStructuredEvents(parser *event.Parser, includeDone bool) []agent.Event {
  1227		events := convertLegacyEvents(parser.Flush())
  1228		if includeDone {
  1229			events = append(events, agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeDone})
  1230		}
  1231		return events
  1232	}
  1233	
  1234	func convertLegacyEvents(legacy []event.Event) []agent.Event {
  1235		var events []agent.Event
  1236		for _, evt := range legacy {
  1237			switch evt.Type {
  1238			case event.TypeThinking:
  1239				events = append(events,
  1240					agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeThinkingStart},
  1241					agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeThinkingDelta, Content: evt.Content},
  1242					agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeThinkingEnd, Content: evt.Content},
  1243				)
  1244			case event.TypeToolStart:
  1245				events = append(events, agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeToolStart, Name: evt.Name})
  1246			case event.TypeToolInput:
  1247				events = append(events, agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeToolInput, Name: evt.Name, Input: evt.Input})
  1248			case event.TypeToolEnd:
  1249				if evt.Input != "" {
  1250					events = append(events, agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeToolInput, Name: evt.Name, Input: evt.Input})
  1251				}
  1252				if evt.Output != "" {
  1253					events = append(events, agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeToolOutput, Name: evt.Name, Output: evt.Output})
  1254				}
  1255				events = append(events, agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeToolEnd, Name: evt.Name, Input: evt.Input, Output: evt.Output})
  1256			case event.TypeToolError, event.TypeError:
  1257				events = append(events, agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeError, Content: evt.Content, Name: evt.Name, Input: evt.Input, Output: evt.Output})
  1258			case event.TypeOutput:
  1259				// Filter transcript markers from output_final content
  1260				content := filterTranscriptMarkers(evt.Content)
  1261				events = append(events, agent.Event{Version: agent.EventProtocolVersion, Type: agent.TypeOutputFinal, Content: content})
  1262			}
  1263		}
  1264		return events
  1265	}
