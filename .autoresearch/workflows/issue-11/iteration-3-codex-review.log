   680	func (s *Server) handleWSMessages(conn *WSConnection) {
   681		defer func() {
   682			s.hub.UnsubscribeAll(conn.ID)
   683			conn.cancel()
   684			_ = conn.Close()
   685			conn.streamWG.Wait()
   686			s.connectionsMu.Lock()
   687			delete(s.connections, conn.ID)
   688			s.connectionsMu.Unlock()
   689			metrics.Default().Gauge(metrics.WSConnections).Dec()
   690		}()
   691	
   692		_ = conn.SetReadDeadline(time.Now().Add(wsPongWait))
   693		conn.SetPongHandler(func(string) error {
   694			return conn.SetReadDeadline(time.Now().Add(wsPongWait))
   695		})
   696	
   697		go s.writePingLoop(conn)
   698	
   699		for {
   700			_, data, err := conn.ReadMessage()
   701			if err != nil {
   702				break
   703			}
   704	
   705			var req JSONRPCRequest
   706			if err := json.Unmarshal(data, &req); err != nil {
   707				_ = conn.SendJSON(JSONRPCResponse{
   708					JSONRPC: "2.0",
   709					Error:   &JSONRPCError{Code: -32700, Message: "Parse error"},
   710				})
   711				continue
   712			}
   713	
