   888	// relaySubscription forwards events from a subscription channel to a WebSocket connection.
   889	func (s *Server) relaySubscription(conn *WSConnection, sessionID string, ch <-chan HubEvent) {
   890		for evt := range ch {
   891			switch {
   892			case evt.Result != nil:
   893				_ = conn.SendJSON(evt.Result)
   894			case evt.Error != nil:
   895				_ = conn.SendJSON(evt.Error)
   896			case evt.Event.Type != "":
   897				_ = conn.SendJSON(newEventNotification(sessionID, "", evt.Event))
   898			case evt.Chunk.Type != "":
   899				_ = conn.SendJSON(JSONRPCRequest{
   900					JSONRPC: "2.0",
   901					Method:  "stream",
   902					Params: map[string]interface{}{
   903						"id":         evt.Chunk.ID,
   904						"session_id": evt.Chunk.SessionID,
   905						"type":       evt.Chunk.Type,
   906						"content":    evt.Chunk.Content,
   907					},
   908				})
   909			}
   910		}
   911	}
