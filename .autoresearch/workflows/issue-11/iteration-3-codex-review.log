   488	func (s *Server) handleJobDetailAPI(w http.ResponseWriter, r *http.Request) {
   489		jobID := strings.TrimPrefix(r.URL.Path, "/api/jobs/")
   490		if jobID == "" {
   491			http.NotFound(w, r)
   492			return
   493		}
   494	
   495		switch r.Method {
   496		case http.MethodGet:
   497			job, ok := s.jobMgr.Get(jobID)
   498			if !ok {
   499				http.NotFound(w, r)
   500				return
   501			}
   502			w.Header().Set("Content-Type", "application/json")
   503			_ = json.NewEncoder(w).Encode(job)
   504		case http.MethodDelete:
   505			if err := s.jobMgr.Delete(jobID); err != nil {
   506				w.WriteHeader(http.StatusNotFound)
   507				_ = json.NewEncoder(w).Encode(map[string]interface{}{"error": err.Error()})
   508				return
   509			}
   510			w.Header().Set("Content-Type", "application/json")
   511			_ = json.NewEncoder(w).Encode(map[string]interface{}{"success": true})
   512		case http.MethodPost:
   513			// Handle job actions (cancel, retry)
   514			var req struct {
   515				Action string `json:"action"`
   516			}
   517			if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
   518				w.WriteHeader(http.StatusBadRequest)
   519				return
   520			}
   521	
   522			switch req.Action {
   523			case "cancel":
   524				if err := s.jobMgr.Cancel(jobID); err != nil {
   525					w.WriteHeader(http.StatusBadRequest)
   526					_ = json.NewEncoder(w).Encode(map[string]interface{}{"error": err.Error()})
   527					return
   528				}
   529				w.Header().Set("Content-Type", "application/json")
   530				_ = json.NewEncoder(w).Encode(map[string]interface{}{"success": true})
   531			default:
   532				w.WriteHeader(http.StatusBadRequest)
   533				_ = json.NewEncoder(w).Encode(map[string]interface{}{"error": "unknown action"})
   534			}
   535		default:
   536			w.WriteHeader(http.StatusMethodNotAllowed)
   537		}
   538	}
