   129		for _, subID := range dropped {
   130			if ch, ok := subs[subID]; ok {
   131				log.Printf("[stream-hub] Dropping slow subscriber %s for session %s", subID, sessionID)
   132				delete(subs, subID)
   133				close(ch)
   134				metrics.Default().Counter(metrics.WSDroppedSubs).Inc()
   135				metrics.Default().Gauge(metrics.WSSubscribers).Dec()
   136			}
   137		}
   138		if len(subs) == 0 {
   139			delete(h.subscribers, sessionID)
   140		}
   141	}
   142	
   143	// SubscriberCount returns the number of active subscribers for a session.
   144	func (h *StreamHub) SubscriberCount(sessionID string) int {
   145		h.mu.RLock()
   146		defer h.mu.RUnlock()
   147		return len(h.subscribers[sessionID])
   148	}
   149	
   150	// HasSubscribers returns true if the session has at least one subscriber.
   151	func (h *StreamHub) HasSubscribers(sessionID string) bool {
   152		h.mu.RLock()
   153		defer h.mu.RUnlock()
   154		return len(h.subscribers[sessionID]) > 0
   155	}

