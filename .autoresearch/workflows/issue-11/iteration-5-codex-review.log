    39	// StreamHub manages per-session fan-out of live stream events.
    40	// Each session can have multiple subscribers; events published to the hub
    41	// are delivered to all of them in order.
    42	type StreamHub struct {
    43		mu          sync.RWMutex
    44		subscribers map[string]map[string]chan HubEvent // sessionID -> subscriberID -> channel
    45	}
    46	
    47	// NewStreamHub creates a new StreamHub.
    48	func NewStreamHub() *StreamHub {
    49		return &StreamHub{
    50			subscribers: make(map[string]map[string]chan HubEvent),
    51		}
    52	}
    53	
    54	// Subscribe registers a subscriber for a session's live stream.
    55	// Returns a channel that will receive all events for that session.
    56	// The caller must call Unsubscribe when done.
    57	func (h *StreamHub) Subscribe(sessionID, subscriberID string) <-chan HubEvent {
    58		ch := make(chan HubEvent, subscriberBufSize)
    59	
    60		h.mu.Lock()
    61		defer h.mu.Unlock()
    62	
    63		if h.subscribers[sessionID] == nil {
    64			h.subscribers[sessionID] = make(map[string]chan HubEvent)
    65		}
    66		h.subscribers[sessionID][subscriberID] = ch
    67		metrics.Default().Gauge(metrics.WSSubscribers).Inc()
    68		return ch
    69	}
    70	
    71	// Unsubscribe removes a subscriber. The subscriber's channel is closed.
    72	func (h *StreamHub) Unsubscribe(sessionID, subscriberID string) {
