  1060	func (s *Server) prepareSession(sessionID, agentType string) *session.Session {
  1061		sess := s.sessionMgr.GetOrCreate(defaultSessionChannel, "", sessionID, agentType)
  1062		if agentType != "" && sess.AgentName != agentType {
  1063			sess.AgentName = agentType
  1064			s.sessionMgr.Update(sess)
  1065			sess, _ = s.sessionMgr.Get(defaultSessionChannel, sessionID)
  1066		}
  1067		s.broadcastSession(sess)
  1068		return sess
  1069	}
  1070	
  1071	func (s *Server) ensureAgentSession(sess *session.Session, ag agent.Agent, requestID string) (string, error) {
  1072		agentSessionHandle := sess.AgentSessionHandle
  1073		if agentSessionHandle != "" {
  1074			return agentSessionHandle, nil
  1075		}
  1076	
  1077		id, err := ag.EnsureSession(context.Background(), sess.ID)
  1078		if err != nil {
  1079			return "", err
  1080		}
  1081		// ACPX prompts are addressed by the stable session name we chose (`sess.ID`).
  1082		// Preserve the returned internal session ID separately for observability.
  1083		sess.AgentSession = id
  1084		sess.AgentSessionHandle = sess.ID
  1085		s.sessionMgr.Update(sess)
  1086		updated, _ := s.sessionMgr.Get(defaultSessionChannel, sess.ID)
  1087		s.broadcastSession(updated)
  1088		log.Printf("[gateway] Created agent session, name=%s, acpx_id=%s, request=%s", sess.ID, id, requestID)
  1089		return sess.AgentSessionHandle, nil
  1090	}
