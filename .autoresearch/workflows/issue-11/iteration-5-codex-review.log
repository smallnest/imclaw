   834	func (s *Server) handleSessionSubscribe(connID string, req *JSONRPCRequest) *JSONRPCResponse {
   835		params, ok := req.Params.(map[string]interface{})
   836		if !ok {
   837			return invalidParams(req.ID)
   838		}
   839		sessionID := getStringParam(params, "session_id")
   840		if sessionID == "" {
   841			return missingParam(req.ID, "session_id")
   842		}
   843		if connID == "" {
   844			return &JSONRPCResponse{JSONRPC: "2.0", ID: req.ID, Error: &JSONRPCError{Code: -32601, Message: "session.subscribe requires WebSocket connection"}}
