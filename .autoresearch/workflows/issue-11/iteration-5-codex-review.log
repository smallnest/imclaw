   541	func (s *Server) executeJobPrompt(ctx context.Context, prompt string, logFn func(level, msg string)) (string, error) {
   542		execStart := time.Now()
   543	
   544		// Create a temporary session for this job
   545		agentType := "acpx"
   546		ag := s.agentMgr.GetOrCreate(agentType)
   547	
   548		// Create a unique session ID for this job
   549		sessionID := uuid.NewString()
   550		agentSessionID, err := ag.EnsureSession(ctx, sessionID)
   551		if err != nil {
   552			return "", fmt.Errorf("failed to create agent session: %w", err)
   553		}
   554	
   555		logFn("info", fmt.Sprintf("Started execution with agent: %s", agentType))
   556	
   557		// Execute the prompt
   558		response, err := ag.PromptWithOptions(ctx, agentSessionID, prompt, &agent.PromptOptions{
   559			NonInteractivePerms: "allow",
   560		})
   561		if err != nil {
   562			logFn("error", fmt.Sprintf("Execution failed: %v", err))
   563			metrics.Default().Counter(metrics.JobFailed).Inc()
   564			metrics.Default().Counter(metrics.AgentExecFailures).Inc()
   565			metrics.LogEvent("job.failed", sessionID, "", map[string]interface{}{
   566				"agent": agentType,
   567				"error": metrics.Truncate(err.Error(), 200),
   568			})
   569			return "", err
   570		}
   571	
   572		metrics.Default().Latency(metrics.JobDuration).Since(execStart)
   573		metrics.Default().Counter(metrics.JobCompleted).Inc()
   574		metrics.Default().Counter(metrics.OutputSize).Add(int64(len(response)))
   575	
   576		logFn("info", "Execution completed successfully")
   577		return response, nil
   578	}
