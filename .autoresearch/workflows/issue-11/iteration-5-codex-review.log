  1191	// filterTranscriptMarkers removes transcript marker lines like [thinking], [tool], [done], [acpx], [client]
  1192	func filterTranscriptMarkers(content string) string {
  1193		lines := strings.Split(content, "\n")
  1194		var filtered []string
  1195		for _, line := range lines {
  1196			trimmed := strings.TrimSpace(line)
  1197			// Skip marker lines
  1198			if trimmed == "[thinking]" ||
  1199				strings.HasPrefix(trimmed, "[thinking] ") ||
  1200				strings.HasPrefix(trimmed, "[tool]") ||
  1201				strings.HasPrefix(trimmed, "[done]") ||
  1202				strings.HasPrefix(trimmed, "[acpx]") ||
  1203				strings.HasPrefix(trimmed, "[client]") {
  1204				continue
  1205			}
  1206			filtered = append(filtered, line)
  1207		}
  1208		return strings.TrimSpace(strings.Join(filtered, "\n"))
  1209	}
