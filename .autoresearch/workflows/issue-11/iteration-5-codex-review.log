    28	}
    29	
    30	// Add increments the counter by n. Panics if n is negative; counters
    31	// must only increase. Use Gauge for values that can decrease.
    32	func (c *Counter) Add(n int64) {
    33		if n < 0 {
    34			log.Printf("[metrics] counter %s: Add called with negative value %d, ignoring", c.name, n)
    35			return
    36		}
    37		v := c.count.Add(n)
    38		log.Printf("[metrics] counter %s=%d delta=%d", c.name, v, n)
    39	}
