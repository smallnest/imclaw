    17	// HubEvent wraps an event or raw stream chunk for fan-out delivery.
    18	type HubEvent struct {
    19		// Exactly one field is set per message.
    20	
    21		// Event holds a structured agent event (tool_start, output_final, etc.).
    22		Event agent.Event
    23		// Chunk holds a raw stream content chunk.
    24		Chunk StreamChunkMsg
