   857	// handleWSSubscribe handles a session.subscribe request over WebSocket.
   858	// It registers the connection as a subscriber to the session's live stream
   859	// and starts a goroutine to relay events from the hub to the connection.
   860	func (s *Server) handleWSSubscribe(conn *WSConnection, req *JSONRPCRequest) {
   861		params, ok := req.Params.(map[string]interface{})
   862		if !ok {
   863			_ = conn.SendJSON(invalidParams(req.ID))
   864			return
   865		}
   866		sessionID := getStringParam(params, "session_id")
   867		if sessionID == "" {
   868			_ = conn.SendJSON(missingParam(req.ID, "session_id"))
   869			return
   870		}
   871		if _, ok := s.sessionMgr.Get(sessionChannelFromParams(params), sessionID); !ok {
   872			_ = conn.SendJSON(&JSONRPCResponse{JSONRPC: "2.0", ID: req.ID, Error: &JSONRPCError{Code: -32602, Message: "Session not found"}})
   873			return
   874		}
   875	
   876		ch := s.hub.Subscribe(sessionID, conn.ID)
   877	
   878		_ = conn.SendJSON(&JSONRPCResponse{JSONRPC: "2.0", ID: req.ID, Result: map[string]interface{}{"subscribed": true, "session_id": sessionID}})
   879	
   880		conn.streamWG.Add(1)
   881		go func() {
   882			defer conn.streamWG.Done()
   883			defer s.hub.Unsubscribe(sessionID, conn.ID)
   884			s.relaySubscription(conn, sessionID, ch)
   885		}()
   886	}
