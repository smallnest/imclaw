   847		if _, ok := s.sessionMgr.Get(sessionChannelFromParams(params), sessionID); !ok {
   848			return &JSONRPCResponse{JSONRPC: "2.0", ID: req.ID, Error: &JSONRPCError{Code: -32602, Message: "Session not found"}}
   849		}
   850	
   851		// The actual subscription relay goroutine is spawned by the WS handler.
   852		// Store the pending subscription so the WS read loop picks it up.
   853		// For the JSON-RPC-over-HTTP path we return a confirmation.
   854		return &JSONRPCResponse{JSONRPC: "2.0", ID: req.ID, Result: map[string]interface{}{"subscribed": true, "session_id": sessionID}}
   855	}
