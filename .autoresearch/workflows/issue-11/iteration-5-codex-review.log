   417	func (m *Manager) Cleanup(maxAge time.Duration) int {
   418		m.mu.Lock()
   419		defer m.mu.Unlock()
   420	
   421		cutoff := time.Now().Add(-maxAge)
   422		count := 0
   423		for key, sess := range m.sessions {
   424			if sess.LastActive.Before(cutoff) {
   425				delete(m.sessions, key)
   426				count++
   427			}
   428		}
   429		return count
   430	}

