// 测试大量日志不会导致内存问题
func TestJobLogMemoryLeak(t *testing.T) {
	mgr := NewManager()
	job := mgr.Submit("test", "test-agent")
	
	// 添加大量日志
	for i := 0; i < 10000; i++ {
		mgr.AddLog(job.ID, "info", fmt.Sprintf("Log entry %d", i))
	}
	
	// List 不应该包含日志
	jobs := mgr.List()
	if len(jobs[0].Logs) != 0 {
		t.Errorf("List() should not include logs")
	}
	
	// Get 应该包含日志（或限制数量）
	retrieved, _ := mgr.Get(job.ID)
	if len(retrieved.Logs) > MaxLogEntries {
		t.Errorf("Logs should be limited to %d", MaxLogEntries)
	}
}

// 性能测试
func BenchmarkListJobs(b *testing.B) {
	mgr := NewManager()
	// 创建 1000 个 Job
	for i := 0; i < 1000; i++ {
		mgr.Submit(fmt.Sprintf("prompt-%d", i), "agent")
	}
	
	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		mgr.List()
	}
}

// 测试排序正确性
func TestListSorting(t *testing.T) {
	mgr := NewManager()
	
	// 创建多个 Job
	ids := make([]string, 5)
	for i := 0; i < 5; i++ {
		job := mgr.Submit(fmt.Sprintf("prompt-%d", i), "agent")
		ids[i] = job.ID
		time.Sleep(10 * time.Millisecond)  // 确保时间戳不同
	}
	
	jobs := mgr.List()
	
	// 验证是降序排列（最新的在前）
	for i := 0; i < len(jobs)-1; i++ {
		if jobs[i].CreatedAt.Before(jobs[i+1].CreatedAt) {
			t.Errorf("Jobs not sorted in descending order")
		}
	}
}
```

