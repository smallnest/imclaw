		params["name"] = evt.Name
	}
	if evt.Input != "" {
		params["input"] = evt.Input
	}
	if evt.Output != "" {
		params["output"] = evt.Output
	}
	return JSONRPCRequest{
		JSONRPC: "2.0",
		Method:  "event",
		Params:  params,
	}
}
